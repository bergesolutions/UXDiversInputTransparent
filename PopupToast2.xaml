<?xml version="1.0" encoding="utf-8" ?>
<popups:PopupPage
    x:Class="UXDiversInputTransparent.PopupToast2"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:popups="clr-namespace:UXDivers.Popups.Maui;assembly=UXDivers.Popups.Maui"
    CascadeInputTransparent="False"
    InputTransparent="True">
    <VerticalStackLayout
        x:Name="RootLayout"
        HorizontalOptions="Fill"
        InputTransparent="False"
        VerticalOptions="Start">

        <Border
            x:Name="ToastFrame"
            Grid.Row="0"
            Padding="8"
            BackgroundColor="Green"
            HorizontalOptions="Fill"
            InputTransparent="False"
            StrokeShape="RoundRectangle 8"
            VerticalOptions="Start">

            <Grid ColumnDefinitions="*,Auto" InputTransparent="False">
                <Label
                    x:Name="ToastLabel"
                    FontSize="14"
                    LineBreakMode="WordWrap"
                    Text="Have some toast"
                    TextColor="White"
                    VerticalOptions="Center"
                    VerticalTextAlignment="Center" />

                <!--  This Button is not working  -->
                <Button
                    x:Name="CloseButton"
                    Grid.Column="1"
                    Padding="8,0"
                    BackgroundColor="Transparent"
                    Clicked="OnCloseClicked"
                    InputTransparent="False"
                    Text="Close"
                    TextColor="White" />
            </Grid>
        </Border>
    </VerticalStackLayout>
</popups:PopupPage>
